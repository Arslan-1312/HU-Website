# Example Environment Variables File
# Do NOT commit your actual .env file to version control.
# Instead, copy this file as `.env` and fill in your actual credentials.

# For Vite, variables that should be exposed to the client must start with "VITE_".
# Example API base URL that the react app can use:
# VITE_PUBLIC_API_URL=https://api.example.com

# For sensitive Keys, do NOT prefix them with "VITE_". Use proxy endpoints in vite.config.js.
# SECRET_API_KEY=your_secret_api_key

VITE_API_BASE_URL=/api
